---
interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  noindex?: boolean;
  ogImage?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  ogImageAlt?: string;
  ogType?: 'website' | 'article';
  ogTitle?: string;
}

const DEFAULT_OG_IMAGE = '/og/bask-og-easiest-fix.png';
const DEFAULT_OG_IMAGE_WIDTH = 1200;
const DEFAULT_OG_IMAGE_HEIGHT = 630;

const {
  title = 'Bask - Vitamin D & Sun Tracker for iOS',
  description = 'Bask translates UV into estimated Vitamin D synthesis, forecasts your daily D-windows, and tracks live sun sessions. Download free on iOS.',
  canonicalPath = '',
  noindex = false,
  ogImage = DEFAULT_OG_IMAGE,
  ogImageWidth = DEFAULT_OG_IMAGE_WIDTH,
  ogImageHeight = DEFAULT_OG_IMAGE_HEIGHT,
  ogImageAlt = 'Tired, poor mood, low energy? Bask helps you get the sunlight you need for Vitamin D. Free on iOS.',
  ogType = 'website',
  ogTitle,
} = Astro.props;

const siteUrl = Astro.site?.href || '';
const baseUrl = siteUrl.replace(/\/$/, '');
const canonicalUrl = `${baseUrl}${canonicalPath}`;
const ogImageUrl = ogImage.startsWith('http')
  ? ogImage
  : `${baseUrl}${ogImage.startsWith('/') ? ogImage : `/${ogImage}`}`;
const socialTitle = ogTitle ?? title;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FFC93C" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />

    <title>{title}</title>

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Bask" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={socialTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content={String(ogImageWidth)} />
    <meta property="og:image:height" content={String(ogImageHeight)} />
    <meta property="og:image:alt" content={ogImageAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={socialTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@600;700;800&family=JetBrains+Mono:wght@600&family=Nunito:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'MobileApplication',
        name: 'Bask',
        description:
          'Bask is an iOS app that translates UV index into estimated Vitamin D synthesis (IU), forecasts daily D-windows, and tracks live sun sessions. Built on peer-reviewed photobiology research with Apple Health sync.',
        applicationCategory: 'HealthApplication',
        operatingSystem: 'iOS',
        offers: {
          '@type': 'Offer',
          price: '0',
          priceCurrency: 'USD',
        },
      })}
    />

    {
      import.meta.env.PROD && (
        <>
          <link rel="preconnect" href="https://cloud.umami.is" />
          <script
            defer
            src="https://cloud.umami.is/script.js"
            data-website-id="9d90c222-65f3-4f0e-b1c9-d198080cb7d0"
          />
        </>
      )
    }

    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import 'tailwindcss';
  @import '../styles/bask.css';

  @custom-variant hover (&:hover);

  @theme inline {
    --color-background: var(--bask-bg);
    --color-foreground: var(--bask-text);
    --color-card: var(--bask-card);
    --color-card-foreground: var(--bask-text);
    --color-popover: var(--bask-card);
    --color-popover-foreground: var(--bask-text);
    --color-primary: var(--bask-sun);
    --color-primary-foreground: var(--bask-text);
    --color-secondary: var(--bask-sky);
    --color-secondary-foreground: var(--bask-text);
    --color-muted: var(--bask-bgAlt);
    --color-muted-foreground: var(--bask-muted);
    --color-accent: var(--bask-honey);
    --color-accent-foreground: var(--bask-text);
    --color-destructive: var(--bask-coral);
    --color-destructive-foreground: #fff;
    --color-border: var(--bask-line);
    --color-input: var(--bask-line);
    --color-ring: var(--bask-sun);

    --radius-sm: 0.5rem;
    --radius-md: 0.75rem;
    --radius-lg: 1rem;
    --radius-xl: 1.5rem;

    --font-sans: 'Nunito', ui-sans-serif, system-ui, sans-serif;
    --font-heading:
      'Bricolage Grotesque', 'Nunito', ui-sans-serif, system-ui, sans-serif;
    --font-display:
      'Bricolage Grotesque', 'Nunito', ui-sans-serif, system-ui, sans-serif;
    --font-mono: 'JetBrains Mono', ui-monospace, monospace;
  }

  :root {
    --background: 40 100% 95%;
    --foreground: 30 38% 12%;
    --primary: 43 100% 61%;
    --primary-foreground: 30 38% 12%;
    --secondary: 197 52% 67%;
    --secondary-foreground: 30 38% 12%;
    --card: 45 100% 98%;
    --card-foreground: 30 38% 12%;
    --popover: 45 100% 98%;
    --popover-foreground: 30 38% 12%;
    --muted: 40 100% 91%;
    --muted-foreground: 30 17% 35%;
    --accent: 35 80% 54%;
    --accent-foreground: 30 38% 12%;
    --destructive: 12 100% 68%;
    --destructive-foreground: 0 0% 100%;
    --border: 38 44% 84%;
    --input: 38 44% 84%;
    --ring: 43 100% 61%;
    --radius: 1rem;
  }

  @layer base {
    html {
      scroll-behavior: smooth;
    }

    * {
      @apply border-border;
    }

    body {
      @apply bg-background text-foreground font-sans antialiased;
    }

    h1,
    h2,
    h3,
    h4,
    h5,
    h6 {
      @apply font-heading font-semibold tracking-tight;
    }
  }

  button,
  a,
  nav,
  [role='button'],
  .no-select {
    @apply select-none;
  }

  [role='presentation'],
  .pointer-none,
  svg[aria-hidden='true'] {
    pointer-events: none;
  }

  .absolute.blur-3xl,
  [class*='blob'],
  [class*='pattern'] {
    @apply pointer-events-none;
  }

  svg:not([role='img']) {
    pointer-events: none;
  }

  section[id] {
    scroll-margin-top: 5rem;
  }

  .glass {
    background: rgba(255, 253, 247, 0.85);
    border: 1px solid var(--bask-line);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
</style>
