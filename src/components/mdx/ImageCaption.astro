---
import { Image } from 'astro:assets';

interface Props {
  src: ImageMetadata;
  alt: string;
  caption?: string;
}

const { src, alt, caption } = Astro.props;
---

<figure class="not-prose my-12">
  <div class="border-border overflow-hidden rounded-xl border shadow-lg">
    <Image
      src={src}
      alt={alt}
      class="h-auto w-full"
      widths={[400, 800, 1200]}
      sizes="(max-width: 768px) 100vw, 800px"
    />
  </div>
  {
    caption && (
      <figcaption class="text-muted-foreground mt-4 text-center text-sm italic">
        {caption}
      </figcaption>
    )
  }
</figure>
