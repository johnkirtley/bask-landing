---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout
  title="Blog | Bask - Vitamin D & Sun Health Insights"
  description="Explore articles about Vitamin D, sun exposure, and health insights from the Bask team. Learn about the science behind Vitamin D synthesis and safe sun practices."
  canonicalPath="/blog"
>
  <div class="bg-background min-h-screen">
    <!-- Hero Section -->
    <section class="relative overflow-hidden py-24 md:py-32">
      <div class="absolute inset-0 -z-10">
        <div
          class="absolute top-1/4 left-1/4 h-96 w-96 rounded-full blur-3xl"
          style="background: color-mix(in srgb, var(--bask-sun) 20%, transparent);"
        >
        </div>
        <div
          class="absolute right-1/4 bottom-1/4 h-96 w-96 rounded-full blur-3xl"
          style="background: color-mix(in srgb, var(--bask-coral) 12%, transparent);"
        >
        </div>
      </div>

      <div class="mx-auto max-w-6xl px-6">
        <div class="mx-auto max-w-3xl text-center">
          <div class="bask-eyebrow mx-auto mb-6">
            <span class="bask-eyebrow-dot"></span>
            From the Bask team
          </div>
          <h1 class="bask-h2 text-foreground mb-6">Bask Blog</h1>
          <p class="text-muted-foreground text-xl md:text-2xl">
            Insights on Vitamin D, sun health, and the science behind safe sun
            exposure
          </p>
        </div>
      </div>
    </section>

    <!-- Blog Posts Grid -->
    <section class="mx-auto max-w-6xl px-6 pb-24">
      {
        posts.length === 0 ? (
          <div class="py-16 text-center">
            <p class="text-muted-foreground text-xl">
              No posts yet. Check back soon!
            </p>
          </div>
        ) : (
          <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
            {posts.map((post) => {
              const formattedDate = new Intl.DateTimeFormat('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              }).format(post.data.pubDate);

              return (
                <article class="group">
                  <a href={`/blog/${post.id}`} class="block">
                    <div class="glass border-border overflow-hidden rounded-2xl border transition-all duration-300 hover:shadow-xl">
                      <div class="bg-muted relative aspect-[16/9] overflow-hidden">
                        <Image
                          src={post.data.heroImage}
                          alt={post.data.title}
                          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-110"
                          widths={[400, 600]}
                          sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
                        />
                      </div>

                      <div class="p-6">
                        <div class="text-muted-foreground mb-4 flex items-center gap-3 text-sm">
                          <time datetime={post.data.pubDate.toISOString()}>
                            {formattedDate}
                          </time>
                          {post.data.readingTime && (
                            <>
                              <span class="text-border">•</span>
                              <span>{post.data.readingTime}</span>
                            </>
                          )}
                        </div>

                        <h2 class="font-heading text-foreground group-hover:text-accent mb-3 text-2xl font-semibold transition-colors">
                          {post.data.title}
                        </h2>

                        <p class="text-foreground/80 line-clamp-3 leading-relaxed">
                          {post.data.description}
                        </p>

                        <div class="text-accent mt-6 flex items-center gap-2 font-semibold transition-all group-hover:gap-3">
                          <span>Read More</span>
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                          >
                            <path d="M5 12h14" />
                            <path d="m12 5 7 7-7 7" />
                          </svg>
                        </div>
                      </div>
                    </div>
                  </a>
                </article>
              );
            })}
          </div>
        )
      }
    </section>
  </div>
</Layout>
