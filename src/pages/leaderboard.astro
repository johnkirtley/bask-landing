---
import Layout from '../layouts/Layout.astro';
import LeaderboardPage from '../components/leaderboard/LeaderboardPage';

const supabaseUrl =
  import.meta.env.PUBLIC_SUPABASE_URL ??
  import.meta.env.NEXT_PUBLIC_SUPABASE_URL ??
  '';
const supabaseAnonKey =
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY ??
  import.meta.env.NEXT_PUBLIC_SUPABASE_ANON_KEY ??
  '';
---

<Layout
  title="Touch Grass Leaderboard | Bask"
  description="See who has the longest Vitamin D goal streak on the Touch Grass Leaderboard. All-time sun stats from Bask users who opt in."
  canonicalPath="/leaderboard"
  ogTitle="Touch Grass Leaderboard | Bask"
  ogImageAlt="Bask Touch Grass Leaderboard — ranked by daily Vitamin D goal streak."
>
  <LeaderboardPage
    client:load
    supabaseUrl={supabaseUrl}
    supabaseAnonKey={supabaseAnonKey}
  />
</Layout>
